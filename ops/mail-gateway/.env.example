# Bind
MAIL_GATEWAY_HOST=127.0.0.1
MAIL_GATEWAY_PORT=8787
MAIL_GATEWAY_PATH=/qrt-alert

# Shared secret expected in header x-captiva-token (or Authorization: Bearer)
MAIL_GATEWAY_TOKEN=change-me-long-random-token

# Provider: smtp | brevo
MAIL_PROVIDER=smtp

# Common sender
MAIL_FROM_EMAIL=contact@optiwealth.fr
MAIL_FROM_NAME=CAPTIVA

# SMTP mode
MAIL_SMTP_HOST=smtp.hostinger.com
MAIL_SMTP_PORT=465
MAIL_SMTP_USER=contact@optiwealth.fr
MAIL_SMTP_PASS=change-me

# Brevo mode (if MAIL_PROVIDER=brevo)
BREVO_API_KEY=change-me
