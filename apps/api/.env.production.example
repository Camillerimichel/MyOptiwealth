# PostgreSQL
DATABASE_URL="postgresql://myoptiwealth_saas:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/myoptiwealth_saas"

# Auth
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_SECRET_LONG_RANDOM"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET_LONG_RANDOM"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
BCRYPT_SALT_ROUNDS="12"

# 32-byte key encoded as base64
AES_SECRET_BASE64="CHANGE_ME_32_BYTES_BASE64"

# API runtime
API_PORT="7000"
REFRESH_COOKIE_NAME="mw_refresh_token"
COOKIE_SECURE="true"

# Documents storage
DOCUMENT_STORAGE_DRIVER="local"
DOCUMENT_LOCAL_BASE_PATH="/var/www/myoptiwealth/storage/documents"
S3_REGION="eu-west-1"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Signature integrations
SIGNATURE_WEBHOOK_TOKEN="CHANGE_ME_WEBHOOK_TOKEN"
YOUSIGN_API_BASE_URL="https://api.yousign.app/v3"
DOCUSIGN_API_BASE_URL="https://demo.docusign.net/restapi/v2.1/accounts/{accountId}"

# Optional seed values
SEED_ADMIN_EMAIL="admin@myoptiwealth.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_WORKSPACE_NAME="MyOptiwealth Demo Workspace"
