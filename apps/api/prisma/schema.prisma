generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN
  COLLABORATOR
  VIEWER
}

enum ProjectPhaseCode {
  QUALIFICATION_CADRAGE
  FORMALISATION_ENGAGEMENT
  ANALYSE_STRUCTURATION
  PRESENTATION_AJUSTEMENTS
  MISE_EN_OEUVRE
  CLOTURE_SUIVI
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
}

enum CalendarEventType {
  MEETING
  TASK_DEADLINE
  INTERNAL
  EXTERNAL
}

enum DocumentStatus {
  DRAFT
  SENT
  SIGNED
  ARCHIVED
}

enum FinancialDocumentType {
  QUOTE
  INVOICE
}

enum ContactRole {
  DECIDEUR
  N_MINUS_1
  OPERATIONNEL
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  firstName         String?
  lastName          String?
  passwordHash      String
  refreshTokenHash  String?
  isPlatformAdmin   Boolean             @default(false)
  twoFactorSecret   String?
  twoFactorEnabled  Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspaceRoles    UserWorkspaceRole[]
  taskAssignments   Task[]              @relation("TaskAssignee")
  timeEntries       TimeEntry[]
  auditLogs         AuditLog[]
}

model Workspace {
  id              String              @id @default(cuid())
  name            String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  settings        WorkspaceSettings?
  members         UserWorkspaceRole[]
  auditLogs       AuditLog[]
  societies       Society[]
  contacts        Contact[]
  projects        Project[]
  tasks           Task[]
  events          CalendarEvent[]
  emails          EmailMessage[]
  documents       Document[]
  financeDocs     FinanceDocument[]
  payments        Payment[]
  timeEntries     TimeEntry[]

  @@index([name])
}

model WorkspaceSettings {
  id                         String    @id @default(cuid())
  workspaceId                String    @unique
  associatedSocietyId        String?
  imapHost                   String?
  imapPort                   Int?
  imapUser                   String?
  imapPasswordEncrypted      String?
  projectTypologies          Json?
  signatureProvider          String?
  signatureApiBaseUrl        String?
  signatureApiKeyEncrypted   String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  workspace                  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([associatedSocietyId])
}

model PlatformSettings {
  id                    String   @id @default(cuid())
  singletonKey          String   @unique @default("GLOBAL")
  imapHost              String?
  imapPort              Int?
  imapUser              String?
  imapPasswordEncrypted String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UserWorkspaceRole {
  id            String        @id @default(cuid())
  userId        String
  workspaceId   String
  role          WorkspaceRole
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

model AuditLog {
  id            String    @id @default(cuid())
  workspaceId   String
  userId        String?
  action        String
  metadata      Json
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}

model Society {
  id            String    @id @default(cuid())
  workspaceId   String
  name          String
  legalForm     String?
  siren         String?
  siret         String?
  addressLine1  String?
  addressLine2  String?
  postalCode    String?
  city          String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts      Contact[]
  projects      Project[]
  documents     Document[]

  @@index([workspaceId])
}

model Contact {
  id            String     @id @default(cuid())
  workspaceId   String
  societyId     String?
  firstName     String
  lastName      String
  role          ContactRole?
  email         String?
  phone         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  society       Society?   @relation(fields: [societyId], references: [id], onDelete: SetNull)
  tasks         TaskContact[]
  ownedTasks    Task[]       @relation("TaskCompanyOwner")
  emails        EmailContact[]
  documents     Document[]
  projectLinks  ProjectContact[]

  @@index([workspaceId])
  @@index([societyId])
}

model Project {
  id                    String         @id @default(cuid())
  workspaceId           String
  societyId             String
  name                  String
  missionType           String?
  currentPhase          ProjectPhaseCode @default(QUALIFICATION_CADRAGE)
  progressPercent       Int            @default(0)
  estimatedFees         Decimal        @default(0)
  invoicedAmount        Decimal        @default(0)
  collectedAmount       Decimal        @default(0)
  estimatedMargin       Decimal        @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  society               Society        @relation(fields: [societyId], references: [id], onDelete: Restrict)
  phases                ProjectPhase[]
  tasks                 Task[]
  events                CalendarEvent[]
  emails                EmailMessage[]
  documents             Document[]
  financeDocuments      FinanceDocument[]
  payments              Payment[]
  timeEntries           TimeEntry[]
  contacts              ProjectContact[]

  @@index([workspaceId])
  @@index([societyId])
}

model ProjectContact {
  projectId    String
  contactId    String
  projectRole  ContactRole?
  createdAt    DateTime   @default(now())
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact      Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([projectId, contactId])
  @@index([contactId])
}

model ProjectPhase {
  id            String          @id @default(cuid())
  workspaceId   String
  projectId     String
  code          ProjectPhaseCode
  title         String
  position      Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks         Task[]

  @@unique([projectId, code])
  @@index([workspaceId])
  @@index([projectId])
}

model Task {
  id              String      @id @default(cuid())
  workspaceId     String
  projectId       String
  projectPhaseId  String?
  startsAfterTaskId String?
  description     String
  privateComment  String?
  startDate       DateTime?
  expectedEndDate DateTime?
  actualEndDate   DateTime?
  planningStartDate DateTime?
  plannedDurationDays Int?
  overrunDays     Int         @default(0)
  planningEndDate DateTime?
  progressPercent Int         @default(0)
  fte             Float       @default(1)
  orderNumber     Int         @default(1)
  priority        Int
  status          TaskStatus  @default(TODO)
  dueDate         DateTime?
  assigneeId      String?
  companyOwnerContactId String?
  visibleToClient Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           ProjectPhase? @relation(fields: [projectPhaseId], references: [id], onDelete: SetNull)
  startsAfterTask Task?       @relation("TaskDependency", fields: [startsAfterTaskId], references: [id], onDelete: SetNull)
  dependentTasks  Task[]      @relation("TaskDependency")
  assignee        User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  companyOwnerContact Contact? @relation("TaskCompanyOwner", fields: [companyOwnerContactId], references: [id], onDelete: SetNull)
  contacts        TaskContact[]
  linkedEmails    TaskEmail[]
  documents       Document[]
  timeEntries     TimeEntry[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([startsAfterTaskId])
  @@index([assigneeId])
  @@index([companyOwnerContactId])
  @@index([workspaceId, status, orderNumber])
}

model TaskContact {
  taskId          String
  contactId       String
  createdAt       DateTime @default(now())
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([taskId, contactId])
}

model EmailMessage {
  id                  String      @id @default(cuid())
  workspaceId         String
  projectId           String?
  externalMessageId   String
  fromAddress         String
  toAddresses         String[]
  subject             String
  receivedAt          DateTime
  metadata            Json
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contacts            EmailContact[]
  tasks               TaskEmail[]

  @@index([workspaceId])
  @@index([projectId])
  @@unique([workspaceId, externalMessageId])
}

model EmailContact {
  emailId        String
  contactId      String
  createdAt      DateTime     @default(now())
  email          EmailMessage  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([emailId, contactId])
}

model TaskEmail {
  taskId       String
  emailId      String
  createdAt    DateTime      @default(now())
  task         Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  email        EmailMessage  @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@id([taskId, emailId])
}

model CalendarEvent {
  id              String            @id @default(cuid())
  workspaceId     String
  projectId       String?
  taskId          String?
  title           String
  description     String?
  eventType       CalendarEventType
  startAt         DateTime
  endAt           DateTime
  visioLink       String?
  alertMinutes    Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId])
}

model Document {
  id                    String         @id @default(cuid())
  workspaceId           String
  projectId             String?
  taskId                String?
  societyId             String?
  contactId             String?
  title                 String
  storagePath           String
  version               Int            @default(1)
  status                DocumentStatus @default(DRAFT)
  signatureProvider     String?
  signatureRequestId    String?
  signatureCertificate  String?
  signatureState        String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project               Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task                  Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  society               Society?       @relation(fields: [societyId], references: [id], onDelete: SetNull)
  contact               Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId])
  @@index([societyId])
  @@index([contactId])
  @@index([signatureRequestId])
}

model FinanceDocument {
  id                  String               @id @default(cuid())
  workspaceId         String
  projectId           String
  quoteId             String?
  invoiceIndex        Int?
  type                FinancialDocumentType
  name                String
  reference           String
  accountingRef       String?
  amount              Decimal
  issuedAt            DateTime
  dueDate             DateTime?
  paidAt              DateTime?
  status              String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quote               FinanceDocument?     @relation("QuoteInvoices", fields: [quoteId], references: [id], onDelete: SetNull)
  invoices            FinanceDocument[]    @relation("QuoteInvoices")

  @@index([workspaceId])
  @@index([projectId])
  @@index([quoteId])
}

model Payment {
  id                  String      @id @default(cuid())
  workspaceId         String
  projectId           String
  amount              Decimal
  paidAt              DateTime
  method              String
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  workspace           Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
}

model TimeEntry {
  id              String    @id @default(cuid())
  workspaceId     String
  projectId       String
  phaseId         String?
  taskId          String?
  userId          String
  minutesSpent    Int
  entryDate       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user            User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@index([projectId])
  @@index([userId])
}
